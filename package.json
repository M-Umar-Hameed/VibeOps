{
  "name": "tickets",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "db:up": "docker compose up -d",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:vector": "tsx -e \"import('./src/db/vector-setup.js').then(m=>m.ensureExtension())\"",
    "db:vector:index": "tsx -e \"import('./src/db/vector-setup.js').then(m=>m.ensureIndex())\"",
    "ingest:watch": "tsx src/ingest/watch.ts",
    "ingest:sessions": "tsx src/ingest/sessions/cli.ts",
    "key": "tsx src/api/generate-key.ts",
    "dev": "tsx watch src/api/server.ts",
    "serve": "tsx src/api/server.ts",
    "mcp": "tsx src/mcp/stdio.ts",
    "relay": "tsx src/relay/runner.ts",
    "sync:github": "tsx src/sync/cli.ts",
    "build:sidecar": "node scripts/build-server.mjs --out app/src-tauri/resources/server && node scripts/fetch-node.mjs --target win-x64 && node scripts/fetch-node.mjs --target linux-x64",
    "build:sidecar:server": "node scripts/build-server.mjs",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.2.17",
    "@hono/node-server": "^1.13.0",
    "@huggingface/transformers": "4.2.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@octokit/rest": "^21.0.0",
    "@opendataloader/pdf": "^2.4.7",
    "chokidar": "^4.0.0",
    "drizzle-orm": "^0.36.0",
    "hono": "^4.6.0",
    "postgres": "^3.4.5",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "drizzle-kit": "^0.28.0",
    "esbuild": "^0.19.12",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
