{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VibeOps",
  "version": "0.1.0",
  "identifier": "com.vibeops.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "VibeOps",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQ1OTUzOENFN0Y5N0FGQUYKUldTdnI1ZC96amlWUmJOSVFYTUduUy9VZm0reGZXa29FT2VhbElRb1U2dm5qSC8xT3g0eDZnaXcK",
      "endpoints": [
        "https://github.com/M-Umar-Hameed/ARC/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": [
      "nsis",
      "deb",
      "appimage"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/server/**/*",
      "resources/node/**/*"
    ],
    "windows": {
      "nsis": {
        "installerHooks": "windows/hooks.nsh"
      }
    }
  },
  "mainBinaryName": "VibeOps"
}
